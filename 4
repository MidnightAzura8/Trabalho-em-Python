# Gastos
joao = 300 + 500 + 200 + 800
pedro = 200 + 300 + 500 + 700

# Exibir totais
print(f"Total João: R$ {joao}")
print(f"Total Pedro: R$ {pedro}")

# Comparação
if joao > pedro:
    print("João gastou mais no mês.")
elif pedro > joao:
    print("Pedro gastou mais no mês.")
else:
    print("Os dois gastaram o mesmo valor.")
